PORT=5000
NODE_ENV=development

# MongoDB — Docker: start with docker-compose up -d mongo, then connect Compass to localhost:27017
MONGO_URI=mongodb://localhost:27017/ambulance_qr

# JWT – access token (short-lived)
JWT_SECRET=change_this_access_secret_min_32_chars
JWT_EXPIRES_IN=15m

# JWT – refresh token (long-lived)
JWT_REFRESH_SECRET=change_this_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# CORS — use https in production so scan/QR URLs use HTTPS
CLIENT_URL=https://localhost:5173

# Logging
LOG_LEVEL=info
